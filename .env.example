# Local-dev environment for `uv run mycelium-http` (and `python -m mycelium`).
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is gitignored. It's loaded by load_dotenv() at startup and NEVER
# overrides a variable already set in the environment — so in deploy
# (ECS Secrets Manager / systemd EnvironmentFile) the injected values win
# and this file is a no-op.

# Anthropic API key for the Ask and Ingest harnesses (read by the
# anthropic SDK). Required for those features to work locally.
ANTHROPIC_API_KEY=

# Substrate data dir. Optional locally — defaults to ./.mycelium.
# MYCELIUM_DATA_DIR=/path/to/your/kb/.mycelium
